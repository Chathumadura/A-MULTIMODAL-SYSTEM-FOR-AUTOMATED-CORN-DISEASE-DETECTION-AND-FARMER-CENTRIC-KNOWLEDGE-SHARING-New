# -----------------------------------------------------------------------
# Corn AI Backend – environment variables
# Copy this file to .env and adjust values for your environment.
# All defaults are safe for LOCAL development (localhost, open CORS).
# -----------------------------------------------------------------------

# ── Server binding ──────────────────────────────────────────────────────────
# Default: localhost only.  Set HOST=0.0.0.0 for production/Docker.
HOST=127.0.0.1
PORT=8000

# ── CORS ────────────────────────────────────────────────────────────────────
# Use * for development.
# Production example: ALLOWED_ORIGINS=https://myapp.com,https://admin.myapp.com
ALLOWED_ORIGINS=*

# ── TensorFlow model (nutrient / disease detection) ─────────────────────────
# Path is resolved relative to the backend/ directory if not absolute.
TF_MODEL_PATH=models/corn_final_model (1).h5
# ── Sklearn pipeline (yield prediction + SHAP) ──────────────────────────────
# Place models/corn_yield_model.tflite inside backend/ and set this path accordingly.
YIELD_MODEL_PATH=models/corn_yield_model.tflite
